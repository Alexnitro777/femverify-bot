{
  "name": "femverify-bot",
  "version": "1.0.0",
  "description": "Discord verification bot with application forms, moderation and appeals",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-sqlite dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --experimental-sqlite src/index.ts",
    "deploy": "ts-node --experimental-sqlite src/deploy-commands.ts"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
