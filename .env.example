DISCORD_TOKEN=your-bot-token
CLIENT_ID=your-client-id
GUILD_ID=your-guild-id

# --- Роли ---
# Выдаётся после успешной верификации
VERIFIED_ROLE_ID=role-id
# Роль ЧСП (чёрный список)
BLACKLIST_ROLE_ID=role-id
# Роль модерации (доступ к каналам-вопросам)
MOD_ROLE_ID=role-id

# --- Каналы ---
# Канал, куда падают заявки на рассмотрение
REVIEW_CHANNEL_ID=channel-id
# Канал, куда падают заявки на амнистию
APPEAL_REVIEW_CHANNEL_ID=channel-id
# Канал, куда отправляется приветственный embed после принятия верификации (необязательно)
WELCOME_CHANNEL_ID=channel-id

# --- Категория для приватных каналов "задать вопрос" ---
QUESTION_CATEGORY_ID=category-id
